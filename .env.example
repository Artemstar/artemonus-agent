# ⚠️ НИКОГДА не коммить .env в GitHub!
# Скопируй этот файл в .env и заполни

# ─── TWITTER / X ──────────────────────────────────────────────────────────────
# Получить на: https://developer.twitter.com/en/portal/dashboard
# Нужен: Free tier (достаточно для постинга)
# Создай App → Keys and Tokens → Generate
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ─── FARCASTER via NEYNAR ─────────────────────────────────────────────────────
# Получить на: https://neynar.com → Dashboard → Create App
# НУЖЕН SIGNER: https://docs.neynar.com/docs/how-to-create-a-signer-with-neynar
# Signer привязывается к твоему Farcaster FID @artemonus
NEYNAR_API_KEY=
NEYNAR_SIGNER_UUID=
